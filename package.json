{
  "name": "focusshift",
  "displayName": "FocusShift",
  "description": "Never lose your coding context — auto chime + smart summary on return",
  "version": "0.1.0",
  "publisher": "FocusShift Team",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "FocusShift",
      "properties": {
        "focusshift.inactivityMinutes": {
          "type": "number",
          "default": 5,
          "description": "Minutes of inactivity before saving state"
        },
        "focusshift.chimeEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable chime sound"
        },
        "focusshift.enableLLMSummary": {
          "type": "boolean",
          "default": true,
          "description": "Use AI (Ollama) to generate context summaries. Disable to use heuristic summaries only."
        },
        "focusshift.useCustomLLM": {
          "type": "boolean",
          "default": true,
          "description": "Use our custom-trained LLM for summaries"
        },
        "focusshift.minAwaySeconds": {
          "type": "number",
          "default": 30,
          "description": "Minimum seconds away before FocusShift shows the context popup."
        }
      }
    },
    "commands": [
      {
        "command": "focusshift.capture",
        "title": "FocusShift: Capture State"
      },
      {
        "command": "focusshift.restore",
        "title": "FocusShift: Restore State"
      },
      {
        "command": "focusshift.testPopup",
        "title": "FocusShift: Test Popup"
      },
      {
        "command": "focusshift.toggleChime",
        "title": "FocusShift: Toggle Chime On/Off"
      },
      {
        "command": "focusshift.testHeuristic",
        "title": "FocusShift: Show Heuristic Summary"
      },
      {
        "command": "focusshift.testLLMSummary",
        "title": "FocusShift: Show LLM Summary"
      },
      {
        "command": "focusshift.showHistory",
        "title": "FocusShift: Show Context History"
      },
      {
        "command": "focusshift.setupOllama",
        "title": "FocusShift: Setup Ollama (AI Summaries)"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/play-sound": "^1.1.2",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.1.0",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@tensorflow-models/universal-sentence-encoder": "^1.3.3",
    "@tensorflow/tfjs": "^4.21.0",
    "@vscode/codicons": "^0.0.45",
    "node-wav-player": "^1.0.0",
    "play-sound": "^1.1.6"
  }
}
